# Database
DATABASE_URL="postgresql://posuser:pospassword@localhost:5432/posdb"

# JWT
JWT_SECRET="pos-super-secret-jwt-key-change-in-production-minimum-256-bits"
JWT_EXPIRY="24h"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=8080
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:3000"

# Email (nodemailer)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER=""
MAIL_PASS=""
MAIL_FROM_EMAIL="receipts@posapp.com"
MAIL_FROM_NAME="POS System"

# File Uploads
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=5242880

# App
APP_BASE_URL="http://localhost:8080"
