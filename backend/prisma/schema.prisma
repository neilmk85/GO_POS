  id              Int      @id @default(autoincrement())
  priceListId     Int      @map("price_list_id")
  productId       Int      @map("product_id")
  variantId       Int?     @map("variant_id")
  sellingPrice    Decimal? @map("selling_price") @db.Decimal(10, 2)
  discountPercent Float?   @map("discount_percent")

  priceList PriceList      @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([priceListId, productId, variantId])
  @@map("price_list_items")
}

model PriceListSegment {
  priceListId Int             @map("price_list_id")
  segment     CustomerSegment

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@id([priceListId, segment])
  @@map("price_list_segments")
}

model PriceListCustomer {
  priceListId Int @map("price_list_id")
  customerId  Int @map("customer_id")

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id])

  @@id([priceListId, customerId])
  @@map("price_list_customers")
}

// ─── Sales Orders ─────────────────────────────────────────────────────────────

model SalesOrder {
  id               Int              @id @default(autoincrement())
  soNumber         String           @unique @map("so_number")
  customerId       Int              @map("customer_id")
  outletId         Int              @map("outlet_id")
  createdByUserId  Int?             @map("created_by_user_id")
  customerPoNumber String?          @map("customer_po_number")
  orderDate        DateTime         @default(now()) @map("order_date") @db.Date
  requiredDate     DateTime?        @map("required_date") @db.Date
  deliveryDate     DateTime?        @map("delivery_date") @db.Date
  status           SalesOrderStatus @default(DRAFT)
  subtotal         Decimal          @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal          @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount        Decimal          @default(0) @map("tax_amount") @db.Decimal(10, 2)
  shippingAmount   Decimal          @default(0) @map("shipping_amount") @db.Decimal(10, 2)
  totalAmount      Decimal          @default(0) @map("total_amount") @db.Decimal(10, 2)
  advanceAmount    Decimal          @default(0) @map("advance_amount") @db.Decimal(10, 2)
  paymentTerms     String?          @map("payment_terms")
  shippingAddress  String?          @map("shipping_address")
  shippingCity     String?          @map("shipping_city")
  shippingState    String?          @map("shipping_state")
  notes            String?
  termsConditions  String?          @map("terms_conditions")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  createdBy        String?          @map("created_by")
  updatedBy        String?          @map("updated_by")

  customer      Customer         @relation(fields: [customerId], references: [id])
  outlet        Outlet           @relation(fields: [outletId], references: [id])
  createdByUser User?            @relation("SalesOrderCreator", fields: [createdByUserId], references: [id])
  items         SalesOrderItem[]

  @@map("sales_orders")
}

model SalesOrderItem {
  id                Int     @id @default(autoincrement())
  salesOrderId      Int     @map("sales_order_id")
  productId         Int     @map("product_id")
  variantId         Int?    @map("variant_id")
  productName       String  @map("product_name")
  sku               String?
  quantity          Decimal @db.Decimal(10, 2)
  deliveredQuantity Decimal @default(0) @map("delivered_quantity") @db.Decimal(10, 2)
  invoicedQuantity  Decimal @default(0) @map("invoiced_quantity") @db.Decimal(10, 2)
  unitPrice         Decimal @map("unit_price") @db.Decimal(10, 2)
  discountPercent   Decimal @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountAmount    Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxRate           Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount         Decimal @default(0) @map("tax_amount") @db.Decimal(10, 2)
  lineTotal         Decimal @map("line_total") @db.Decimal(10, 2)
  notes             String?

  salesOrder SalesOrder      @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id])
  variant    ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("sales_order_items")
}
