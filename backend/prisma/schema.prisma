// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────────────────────────────────────────

enum RoleName {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  INVENTORY_MANAGER
  ACCOUNTANT
}

enum ProductType {
  PHYSICAL
  SERVICE
  DIGITAL
  COMBO
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  HELD
}

enum OrderType {
  SALE
  RETURN
  EXCHANGE
  CREDIT_SALE
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  NET_BANKING
  CREDIT_NOTE
  LOYALTY_POINTS
  CREDIT_SALE
  ADVANCE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum CustomerSegment {
  REGULAR
  SILVER
  GOLD
  VIP
  WHOLESALE
}

enum CreditNoteStatus {
  ACTIVE
  FULLY_USED
  EXPIRED
  CANCELLED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum AdjustmentReason {
  DAMAGE
  THEFT
  EXPIRY
  CORRECTION
  OPENING_STOCK
  AUDIT
  OTHER
}

enum TransferStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  CANCELLED
  PARTIALLY_RECEIVED
}

enum POStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

enum BillStatus {
  DRAFT
  UNPAID
  PARTIAL
  PAID
}

enum PurchaseReturnStatus {
  COMPLETED
  CANCELLED
}

enum CreditMethod {
  CASH
  BANK_TRANSFER
  VENDOR_CREDIT
}

enum DiscountType {
  MANUAL
  AUTOMATIC
  PROMOTIONAL
  FESTIVAL
  LOYALTY
}

enum ApplyOn {
  PRODUCT
  CATEGORY
  CART
  CUSTOMER
}

enum ValueType {
  PERCENTAGE
  FLAT
  BUY_X_GET_Y
  FREE_ITEM
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExpensePaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  CHEQUE
  OTHER
}

enum SupplyType {
  INTRA_STATE
  INTER_STATE
}

enum RecurrenceInterval {
  WEEKLY
  MONTHLY
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  PARTIALLY_DELIVERED
  DELIVERED
  INVOICED
  CANCELLED
  ON_HOLD
}

enum ConversionStatus {
  NOT_CONVERTED
  PARTIALLY_CONVERTED
  CONVERTED
}

enum IncentiveRuleType {
  COMMISSION
  TARGET_BONUS
  PER_TRANSACTION
  TIERED_COMMISSION
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  ADJUSTED
  BONUS
}

// ────────────────────────────────────────────────────────────────────────────
// CORE MODELS
// ────────────────────────────────────────────────────────────────────────────

model Role {
  id   Int      @id @default(autoincrement())
  name RoleName @unique

  userRoles UserRole[]

  @@map("roles")
}

model Outlet {
  id                   Int      @id @default(autoincrement())
  name                 String
  code                 String?  @unique
  address              String?
  city                 String?
  state                String?
  pincode              String?
  country              String?
  phone                String?
  phone2               String?
  email                String?
  gstin                String?
  pan                  String?
  currencyCode         String   @default("INR") @map("currency_code")
  currencySymbol       String   @default("₹") @map("currency_symbol")
  active               Boolean  @default(true) @map("is_active")
  receiptHeader        String?  @map("receipt_header")
  receiptFooter        String?  @map("receipt_footer")
  printReceiptByDefault Boolean @default(true) @map("print_receipt_by_default")
  showTaxBreakdown     Boolean  @default(true) @map("show_tax_breakdown")
  showBarcodeOnReceipt Boolean  @default(true) @map("show_barcode_on_receipt")
  invoiceTemplate      String?  @db.Text @map("invoice_template")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  createdBy            String?  @map("created_by")
  updatedBy            String?  @map("updated_by")

  users              User[]
  inventories        Inventory[]
  orders             Order[]
  invoices           Invoice[]
  quotations         Quotation[]
  creditNotes        CreditNote[]
  shifts             Shift[]
  stockAdjustments   StockAdjustment[]
  stockTransfersFrom StockTransfer[] @relation("FromOutlet")
  stockTransfersTo   StockTransfer[] @relation("ToOutlet")
  purchaseOrders     PurchaseOrder[]
  purchaseBills      PurchaseBill[]
  purchaseReturns    PurchaseReturn[]
  expenses           Expense[]
  bulkPurchases      BulkPurchase[]
  incentiveRules     IncentiveRule[]
  integrationConfig  IntegrationConfig?
  salesOrders        SalesOrder[]

  @@map("outlets")
}

model User {
  id                Int       @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  phone             String?
  employeeCode      String?   @unique @map("employee_code")
  pinCode           String?   @map("pin_code")
  outletId          Int?      @map("outlet_id")
  active            Boolean   @default(true) @map("is_active")
  lastLogin         DateTime? @map("last_login")
  profileImage      String?   @map("profile_image")
  maxDiscountPercent Float    @default(10.0) @map("max_discount_percent")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  createdBy         String?   @map("created_by")
  updatedBy         String?   @map("updated_by")

  outlet              Outlet?           @relation(fields: [outletId], references: [id])
  userRoles           UserRole[]
  cashierOrders       Order[]           @relation("Cashier")
  cashierShifts       Shift[]           @relation("CashierShift")
  adjustedBy          StockAdjustment[] @relation("AdjustedBy")
  requestedTransfers  StockTransfer[]   @relation("RequestedBy")
  approvedTransfers   StockTransfer[]   @relation("ApprovedBy")
  receivedTransfers   StockTransfer[]   @relation("ReceivedBy")
  purchaseOrders      PurchaseOrder[]   @relation("CreatedByUser")
  salesOrders         SalesOrder[]      @relation("SalesOrderCreator")

  @@map("users")
}

model UserRole {
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Category {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  imageUrl     String?  @map("image_url")
  displayOrder Int      @default(0) @map("display_order")
  active       Boolean  @default(true) @map("is_active")
  parentId     Int?     @map("parent_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    String?  @map("created_by")
  updatedBy    String?  @map("updated_by")

  parent            Category?          @relation("CategoryParent", fields: [parentId], references: [id])
  children          Category[]         @relation("CategoryParent")
  products          Product[]
  discountCategories DiscountCategory[]

  @@map("categories")
}

model TaxGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  totalRate   Decimal  @map("total_rate") @db.Decimal(5, 2)
  cgstRate    Decimal? @map("cgst_rate") @db.Decimal(5, 2)
  sgstRate    Decimal? @map("sgst_rate") @db.Decimal(5, 2)
  igstRate    Decimal? @map("igst_rate") @db.Decimal(5, 2)
  cessRate    Decimal  @default(0) @map("cess_rate") @db.Decimal(5, 2)
  hsnCode     String?  @map("hsn_code")
  inclusive   Boolean  @default(false) @map("is_inclusive")
  active      Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")

  products Product[]

  @@map("tax_groups")
}

model Product {
  id                 Int         @id @default(autoincrement())
  name               String
  description        String?
  sku                String?     @unique
  barcode            String?
  categoryId         Int?        @map("category_id")
  taxGroupId         Int?        @map("tax_group_id")
  costPrice          Decimal?    @map("cost_price") @db.Decimal(10, 2)
  sellingPrice       Decimal     @map("selling_price") @db.Decimal(10, 2)
  mrp                Decimal?    @db.Decimal(10, 2)
  minSellingPrice    Decimal?    @map("min_selling_price") @db.Decimal(10, 2)
  unitOfMeasure      String      @default("pcs") @map("unit_of_measure")
  purchaseUom        String?     @map("purchase_uom")
  saleUom            String?     @map("sale_uom")
  purchaseFactor     Decimal     @default(1) @map("purchase_factor") @db.Decimal(10, 4)
  saleFactor         Decimal     @default(1) @map("sale_factor") @db.Decimal(10, 4)
  productType        ProductType @default(PHYSICAL) @map("product_type")
  trackInventory     Boolean     @default(true) @map("track_inventory")
  allowNegativeStock Boolean     @default(false) @map("allow_negative_stock")
  reorderLevel       Int         @default(10) @map("reorder_level")
  imageUrl           String?     @map("image_url")
  active             Boolean     @default(true) @map("is_active")
  featured           Boolean     @default(false) @map("is_featured")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  createdBy          String?     @map("created_by")
  updatedBy          String?     @map("updated_by")

  category           Category?          @relation(fields: [categoryId], references: [id])
  taxGroup           TaxGroup?          @relation(fields: [taxGroupId], references: [id])
  variants           ProductVariant[]
  images             ProductImage[]
  inventories        Inventory[]
  orderItems         OrderItem[]
  invoiceItems       InvoiceItem[]
  quotationItems     QuotationItem[]
  discountProducts   DiscountProduct[]
  bulkPurchases      BulkPurchase[]
  purchaseOrderItems PurchaseOrderItem[]
  purchaseBillItems  PurchaseBillItem[]
  purchaseReturnItems PurchaseReturnItem[]
  stockAdjustments   StockAdjustment[]
  stockTransferItems StockTransferItem[]
  conversionTargets  BulkPurchaseConversion[] @relation("TargetProduct")
  priceListItems     PriceListItem[]
  salesOrderItems    SalesOrderItem[]

  @@map("products")
}

model ProductVariant {
  id              Int      @id @default(autoincrement())
  productId       Int      @map("product_id")
  name            String
  sku             String?  @unique
  barcode         String?
  attribute1Name  String?  @map("attribute1_name")
  attribute1Value String?  @map("attribute1_value")
  attribute2Name  String?  @map("attribute2_name")
  attribute2Value String?  @map("attribute2_value")
  priceAdjustment Decimal  @default(0) @map("price_adjustment") @db.Decimal(10, 2)
  costPrice       Decimal? @map("cost_price") @db.Decimal(10, 2)
  imageUrl        String?  @map("image_url")
  active          Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdBy       String?  @map("created_by")
  updatedBy       String?  @map("updated_by")

  product            Product            @relation(fields: [productId], references: [id])
  orderItems         OrderItem[]
  inventories        Inventory[]
  purchaseOrderItems PurchaseOrderItem[]
  stockAdjustments   StockAdjustment[]
  stockTransferItems StockTransferItem[]
  priceListItems     PriceListItem[]
  salesOrderItems    SalesOrderItem[]

  @@map("product_variants")
}

model ProductImage {
  id           Int     @id @default(autoincrement())
  productId    Int     @map("product_id")
  imageUrl     String  @map("image_url")
  primary      Boolean @default(false) @map("is_primary")
  displayOrder Int     @default(0) @map("display_order")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_images")
}

model Customer {
  id              Int             @id @default(autoincrement())
  name            String
  phone           String?         @unique
  phone2          String?
  email           String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  gstin           String?
  dateOfBirth     DateTime?       @map("date_of_birth") @db.Date
  anniversaryDate DateTime?       @map("anniversary_date") @db.Date
  segment         CustomerSegment @default(REGULAR)
  loyaltyPoints   Decimal         @default(0) @map("loyalty_points") @db.Decimal(10, 2)
  totalSpent      Decimal         @default(0) @map("total_spent") @db.Decimal(10, 2)
  creditLimit     Decimal         @default(0) @map("credit_limit") @db.Decimal(10, 2)
  outstandingDue  Decimal         @default(0) @map("outstanding_due") @db.Decimal(10, 2)
  discountPercent Float           @default(0) @map("discount_percent")
  active          Boolean         @default(true) @map("is_active")
  blacklisted     Boolean         @default(false) @map("is_blacklisted")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  createdBy       String?         @map("created_by")
  updatedBy       String?         @map("updated_by")

  orders             Order[]
  invoices           Invoice[]
  quotations         Quotation[]
  creditNotes        CreditNote[]
  loyaltyTransactions LoyaltyTransaction[]
  coupons            Coupon[]
  priceListCustomers PriceListCustomer[]
  salesOrders        SalesOrder[]

  @@map("customers")
}

model Inventory {
  id                 Int      @id @default(autoincrement())
  productId          Int      @map("product_id")
  variantId          Int?     @map("variant_id")
  outletId           Int      @map("outlet_id")
  quantityOnHand     Decimal  @default(0) @map("quantity_on_hand") @db.Decimal(10, 2)
  quantityReserved   Decimal  @default(0) @map("quantity_reserved") @db.Decimal(10, 2)
  quantityInTransit  Decimal  @default(0) @map("quantity_in_transit") @db.Decimal(10, 2)
  reorderLevel       Int      @default(10) @map("reorder_level")
  reorderQuantity    Int      @default(50) @map("reorder_quantity")
  lastStockUpdate    DateTime? @map("last_stock_update")
  averageCost        Decimal?  @map("average_cost") @db.Decimal(10, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  createdBy          String?  @map("created_by")
  updatedBy          String?  @map("updated_by")

  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  outlet  Outlet         @relation(fields: [outletId], references: [id])

  @@unique([productId, variantId, outletId])
  @@map("inventory")
}

model Order {
  id                  Int         @id @default(autoincrement())
  orderNumber         String      @unique @map("order_number")
  outletId            Int         @map("outlet_id")
  cashierId           Int         @map("cashier_id")
  shiftId             Int?        @map("shift_id")
  customerId          Int?        @map("customer_id")
  status              OrderStatus @default(PENDING)
  orderType           OrderType   @default(SALE) @map("order_type")
  subtotal            Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount      Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount           Decimal     @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount         Decimal     @default(0) @map("total_amount") @db.Decimal(10, 2)
  paidAmount          Decimal     @default(0) @map("paid_amount") @db.Decimal(10, 2)
  changeAmount        Decimal     @default(0) @map("change_amount") @db.Decimal(10, 2)
  loyaltyPointsEarned Decimal     @default(0) @map("loyalty_points_earned") @db.Decimal(10, 2)
  loyaltyPointsUsed   Decimal     @default(0) @map("loyalty_points_used") @db.Decimal(10, 2)
  couponCode          String?     @map("coupon_code")
  discountReason      String?     @map("discount_reason")
  approvedById        Int?        @map("approved_by_id")
  notes               String?
  receiptSentEmail    Boolean     @default(false) @map("receipt_sent_email")
  receiptSentSms      Boolean     @default(false) @map("receipt_sent_sms")
  receiptSentWhatsapp Boolean     @default(false) @map("receipt_sent_whatsapp")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  createdBy           String?     @map("created_by")
  updatedBy           String?     @map("updated_by")

  outlet              Outlet               @relation(fields: [outletId], references: [id])
  cashier             User                 @relation("Cashier", fields: [cashierId], references: [id])
  shift               Shift?               @relation(fields: [shiftId], references: [id])
  customer            Customer?            @relation(fields: [customerId], references: [id])
  items               OrderItem[]
  payments            Payment[]
  invoices            Invoice[]
  creditNotes         CreditNote[]
  loyaltyTransactions LoyaltyTransaction[]

  @@map("orders")
}

model OrderItem {
  id               Int     @id @default(autoincrement())
  orderId          Int     @map("order_id")
  productId        Int     @map("product_id")
  variantId        Int?    @map("variant_id")
  productName      String  @map("product_name")
  variantName      String? @map("variant_name")
  sku              String?
  quantity         Decimal @db.Decimal(10, 2)
  unitPrice        Decimal @map("unit_price") @db.Decimal(10, 2)
  costPrice        Decimal? @map("cost_price") @db.Decimal(10, 2)
  discountPercent  Decimal @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountAmount   Decimal @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount        Decimal @default(0) @map("tax_amount") @db.Decimal(10, 2)
  taxRate          Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  lineTotal        Decimal @map("line_total") @db.Decimal(10, 2)
  notes            String?
  returnedQuantity Decimal @default(0) @map("returned_quantity") @db.Decimal(10, 2)

  order   Order          @relation(fields: [orderId], references: [id])
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Payment {
  id                   Int           @id @default(autoincrement())
  orderId              Int           @map("order_id")
  paymentMethod        PaymentMethod @map("payment_method")
  amount               Decimal       @db.Decimal(10, 2)
  referenceNumber      String?       @map("reference_number")
  gatewayTransactionId String?       @map("gateway_transaction_id")
  status               PaymentStatus @default(COMPLETED)
  creditNoteId         Int?          @map("credit_note_id")
  notes                String?
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  createdBy            String?       @map("created_by")
  updatedBy            String?       @map("updated_by")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Invoice {
  id               Int           @id @default(autoincrement())
  invoiceNumber    String        @unique @map("invoice_number")
  orderId          Int?          @map("order_id")
  customerId       Int?          @map("customer_id")
  outletId         Int           @map("outlet_id")
  issueDate        DateTime      @map("issue_date") @db.Date
  dueDate          DateTime?     @map("due_date") @db.Date
  status           InvoiceStatus @default(DRAFT)
  subtotal         Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount        Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount      Decimal       @default(0) @map("total_amount") @db.Decimal(10, 2)
  paidAmount       Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  notes            String?
  termsConditions  String?       @map("terms_conditions")
  paymentTerms     String?       @map("payment_terms")
  billDiscountPct  Decimal       @default(0) @map("bill_discount_pct") @db.Decimal(5, 2)
  billDiscountAmt  Decimal       @default(0) @map("bill_discount_amt") @db.Decimal(10, 2)
  poNumber         String?       @map("po_number")
  shippingAmount   Decimal       @default(0) @map("shipping_amount") @db.Decimal(10, 2)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  createdBy        String?       @map("created_by")
  updatedBy        String?       @map("updated_by")

  order    Order?        @relation(fields: [orderId], references: [id])
  customer Customer?     @relation(fields: [customerId], references: [id])
  outlet   Outlet        @relation(fields: [outletId], references: [id])
  items    InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id             Int     @id @default(autoincrement())
  invoiceId      Int     @map("invoice_id")
  productId      Int?    @map("product_id")
  productName    String  @map("product_name")
  productSku     String? @map("product_sku")
  quantity       Decimal @db.Decimal(10, 2)
  unitPrice      Decimal @map("unit_price") @db.Decimal(10, 2)
  discountPercent Decimal @default(0) @map("discount_percent") @db.Decimal(5, 2)
  taxRate        Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  lineTotal      Decimal @map("line_total") @db.Decimal(10, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model Quotation {
  id               Int             @id @default(autoincrement())
  quotationNumber  String          @unique @map("quotation_number")
  customerId       Int?            @map("customer_id")
  outletId         Int             @map("outlet_id")
  validUntil       DateTime?       @map("valid_until") @db.Date
  status           QuotationStatus @default(DRAFT)
  subtotal         Decimal         @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal         @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount        Decimal         @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount      Decimal         @default(0) @map("total_amount") @db.Decimal(10, 2)
  notes            String?
  termsConditions  String?         @map("terms_conditions")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  createdBy        String?         @map("created_by")
  updatedBy        String?         @map("updated_by")

  customer Customer?      @relation(fields: [customerId], references: [id])
  outlet   Outlet         @relation(fields: [outletId], references: [id])
  items    QuotationItem[]

  @@map("quotations")
}

model QuotationItem {
  id              Int     @id @default(autoincrement())
  quotationId     Int     @map("quotation_id")
  productId       Int?    @map("product_id")
  productName     String  @map("product_name")
  productSku      String? @map("product_sku")
  quantity        Decimal @db.Decimal(10, 2)
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)
  discountPercent Decimal @default(0) @map("discount_percent") @db.Decimal(5, 2)
  taxRate         Decimal @default(0) @map("tax_rate") @db.Decimal(5, 2)
  lineTotal       Decimal @map("line_total") @db.Decimal(10, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id])
  product   Product?  @relation(fields: [productId], references: [id])

  @@map("quotation_items")
}

model CreditNote {
  id               Int              @id @default(autoincrement())
  creditNoteNumber String           @unique @map("credit_note_number")
  customerId       Int              @map("customer_id")
