# Database Configuration
DB_DSN=root:root@tcp(localhost:3306)/posdb?charset=utf8mb4&parseTime=True&loc=Local

# JWT Configuration
JWT_SECRET=pos-super-secret-jwt-key-change-in-production
JWT_EXPIRY=720h
JWT_REFRESH_EXPIRY=8760h

# Server Configuration
PORT=8080
ENV=development
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Optional: Email Configuration (if needed)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@pos.local
# EMAIL_FROM_NAME=POS System
